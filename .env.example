# ===========================================
# Database
# ===========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/omnichat?schema=public"

# ===========================================
# Redis
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# JWT Auth
# ===========================================
JWT_SECRET="change-me-to-random-string"
JWT_REFRESH_SECRET="change-me-to-another-random-string"

# ===========================================
# LINE Messaging API
# ===========================================
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""

# ===========================================
# Facebook / Instagram (Meta Graph API)
# ===========================================
META_APP_SECRET=""
META_VERIFY_TOKEN=""
FACEBOOK_PAGE_ACCESS_TOKEN=""

# ===========================================
# AI Chatbot (เลือกอย่างใดอย่างหนึ่ง)
# ===========================================
# Option 1: Anthropic API โดยตรง
ANTHROPIC_API_KEY=""

# Option 2: OpenRouter (ใช้ได้หลาย model: Claude, GPT, Llama ฯลฯ)
OPENROUTER_API_KEY=""

# Override model (optional)
# Anthropic:   claude-sonnet-4-20250514, claude-haiku-4-5-20251001
# OpenRouter:  anthropic/claude-sonnet-4-20250514, openai/gpt-4o, google/gemini-2.0-flash
AI_MODEL=""

# ===========================================
# File Storage (Cloudflare R2 / S3-compatible)
# ===========================================
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="omnichat-media"
S3_REGION="auto"

# ===========================================
# App
# ===========================================
API_PORT=4000
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:4000"
